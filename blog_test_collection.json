  "item": [
    {
      "name": "01-创建帖子",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. 验证创建成功（状态码200）\r",
              "pm.test(\"创建文章成功，状态码200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// 2. 获取返回的HTML\r",
              "const html = pm.response.text();\r",
              "\r",
              "// 3. 用正则提取所有文章ID\r",
              "const idPattern = /\\/article\\/view\\/(\\d+)/g;\r",
              "let match;\r",
              "const ids = [];\r",
              "while ((match = idPattern.exec(html)) !== null) {\r",
              "    ids.push(parseInt(match[1]));\r",
              "}\r",
              "\r",
              "// 4. 找出最大的ID（最新创建的文章）\r",
              "const newId = Math.max(...ids);\r",
              "console.log(\"当前所有文章ID:\", ids);\r",
              "console.log(\"最新创建的文章ID:\", newId);\r",
              "\r",
              "// 5. 保存到全局变量\r",
              "pm.globals.set(\"newArticleId\", parseInt(newId));\r",
              "\r",
              "// 6. 断言：成功提取到新ID\r",
              "pm.test(\"成功提取新创建的文章ID\", function () {\r",
              "    pm.expect(newId).to.be.above(0);\r",
              "});\r",
              "\r",
              "// 7. 验证新创建的文章标题出现在列表中\r",
              "pm.test(\"列表中包含新创建的文章标题\", function () {\r",
              "    pm.expect(html).to.include(\"正则提取测试\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": " application/x-www-form-urlencoded",
            "type": "text"
          },
          {
            "key": "ngrok-skip-browser-warning",
            "value": "true",
            "type": "text"
          }
        ],
        "body": {
